# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to browser

# ---------------------------------------------------------------------------
# Admin authentication (JWT)
# ---------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
JWT_EXPIRE_MINUTES=480
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# ---------------------------------------------------------------------------
# Optional: override API base URL (leave empty to use same-origin /api/*)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=
