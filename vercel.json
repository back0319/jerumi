{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "services",
  "experimentalServices": {
    "web": {
      "entrypoint": "frontend",
      "framework": "nextjs",
      "routePrefix": "/"
    },
    "api": {
      "entrypoint": "backend/main.py",
      "framework": "fastapi",
      "routePrefix": "/api",
      "maxDuration": 60,
      "excludeFiles": "{backend/alembic/**,backend/shade_images/**,backend/uploads/**,backend/**/__pycache__/**}"
    }
  }
}
