{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "services",
  "experimentalServices": {
    "web": {
      "entrypoint": "frontend",
      "framework": "nextjs",
      "routePrefix": "/"
    },
    "api": {
      "entrypoint": "backend/main.py",
      "framework": "fastapi",
      "routePrefix": "/api",
      "maxDuration": 60,
      "excludeFiles": "{backend/alembic/**,backend/tests/**,backend/shade_images/**,backend/uploads/**,backend/.pytest_cache/**,backend/.mypy_cache/**,backend/.ruff_cache/**,backend/**/__pycache__/**,backend/Dockerfile,backend/alembic.ini,backend/requirements-dev.txt}"
    }
  }
}
